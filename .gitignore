# =========================================================================
# eduAI365 — Production .gitignore for Hostinger VPS with Dokploy
# =========================================================================

# --- Documentation ---
# Exclude the documentation folder and root-level DOCX/PDF/text worksheets from Git.
/docs/
/*.docx
/*.pdf
/*.xlsx
/*.pptx

# --- Environment & Secrets (Crucial for Production Security) ---
# Ignore all environment configurations to prevent leaking secrets.
# Production secrets should be set in the Dokploy dashboard environment variables.
.env
.env.local
.env.production
.env.development
.env.test
.env.prod
.env.dev
.env.*
!.env.example

# --- Dependencies & Package Manager ---
node_modules/
.pnpm-store/

# --- Build Outputs & Caches (Next.js, Turborepo, NestJS, Vite) ---
dist/
.next/
out/
build/
.turbo/
.cache/
*.tsbuildinfo
storybook-static/

# --- Local Docker & DB Data Volumes ---
# Excludes local docker-compose overrides and local database volumes.
docker-compose.override.yml
docker-compose.local.yml
.docker/
/data/
*postgres_data/
*redis_data/
*minio_data/
*loki_data/
*prometheus_data/
*grafana_data/

# --- Prisma & Database Files ---
*.db
*.db-journal
*.sqlite
*.sqlite-journal
services/*/prisma/*.db
services/*/prisma/*.db-journal
packages/database/prisma/*.db
packages/database/prisma/*.db-journal

# --- Logs & Test Reports ---
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/
.nyc_output/

# --- IDE, Editors & System files ---
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# --- Misc & Temp Files ---
*.pem
*.key
*.cert
/apiFetch_usages.txt
