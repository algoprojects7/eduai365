# ─── Application ───────────────────────────────────────────
NODE_ENV=development
APP_NAME=eduAI365
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# ─── Domain & Portal URLs ──────────────────────────────
DOMAIN=localhost
ADMIN_URL=http://localhost:3001
PARENT_URL=http://localhost:3005
# Production examples:
# DOMAIN=eduai365.com
# APP_URL=https://eduai365.com
# API_URL=https://api.eduai365.com
# ADMIN_URL=https://superadmin.eduai365.com

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://educore:educore_dev@localhost:5432/educore_ai?schema=public

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO / S3 ────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=educore_minio
MINIO_SECRET_KEY=educore_minio_secret
MINIO_BUCKET=educore-assets
MINIO_USE_SSL=false

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI (Phase 12) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ─── Monitoring ────────────────────────────────────────────
LOKI_URL=http://localhost:3100
