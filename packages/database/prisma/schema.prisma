// ─── Communication & Notifications ───────────────────────────────────────────

model Notice {
  id          String         @id @default(cuid())
  schoolId    String
  title       String
  body        String
  category    NoticeCategory
  isPinned    Boolean        @default(false)
  isPublished Boolean        @default(true)
  publishedAt DateTime       @default(now())
  expiresAt   DateTime?
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy User              @relation("NoticeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  logs      NotificationLog[]

  @@index([schoolId, category])
  @@index([schoolId, isPublished])
  @@map("notices")
}

model Circular {
  id             String   @id @default(cuid())
  schoolId       String
  title          String
  body           String
  audienceFilter Json     @default("{}")
  publishedAt    DateTime @default(now())
  createdById    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy User              @relation("CircularCreator", fields: [createdById], references: [id], onDelete: Cascade)
  logs      NotificationLog[]

  @@index([schoolId])
  @@map("circulars")
}

model ComplaintThread {
  id            String  @id @default(cuid())
  schoolId      String
  subject       String
  description   String
  status        String  @default("SUBMITTED")
  submittedById String
  assignedToId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  submittedBy User               @relation("ComplaintSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
  assignedTo  User?              @relation("ComplaintAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages    ComplaintMessage[]

  @@index([schoolId, status])
  @@index([submittedById])
  @@map("complaint_threads")
}

model ComplaintMessage {
  id           String  @id @default(cuid())
  threadId     String
  senderId     String
  body         String
  isStaffReply Boolean @default(false)

  createdAt DateTime @default(now())

  thread ComplaintThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User            @relation("ComplaintMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("complaint_messages")
}

model BroadcastCampaign {
  id              String            @id @default(cuid())
  schoolId        String
  title           String
  message         String
  channels        DeliveryChannel[]
  audienceFilter  Json              @default("{}")
  status          String            @default("DRAFT")
  scheduledAt     DateTime?
  sentAt          DateTime?
  createdById     String
  totalRecipients Int               @default(0)
  deliveredCount  Int               @default(0)
  failedCount     Int               @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy User              @relation("BroadcastCreator", fields: [createdById], references: [id], onDelete: Cascade)
  logs      NotificationLog[]

  @@index([schoolId, status])
  @@map("broadcast_campaigns")
}

model NotificationLog {
  id               String          @id @default(cuid())
  schoolId         String
  channel          DeliveryChannel
  status           DeliveryStatus  @default(PENDING)
  recipientId      String?
  recipientContact String?
  subject          String?
  body             String
  campaignId       String?
  circularId       String?
  noticeId         String?
  sentAt           DateTime?
  deliveredAt      DateTime?
  failedAt         DateTime?
  errorMessage     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  recipient User?              @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
  campaign  BroadcastCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  circular  Circular?          @relation(fields: [circularId], references: [id], onDelete: SetNull)
  notice    Notice?            @relation(fields: [noticeId], references: [id], onDelete: SetNull)

  @@index([schoolId, channel, status])
  @@index([campaignId])
  @@index([recipientId])
  @@map("notification_logs")
}

