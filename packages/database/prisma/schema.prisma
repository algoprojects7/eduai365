generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantPlan {
  CORE
  PRO
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  PRINCIPAL
  VICE_PRINCIPAL
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  RECEPTIONIST
  LIBRARIAN
  TRANSPORT_MANAGER
  HR_MANAGER
  HOSTEL_WARDEN
  EXAM_CONTROLLER
  COUNSELLOR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  WITHDRAWN
}

enum AdmissionStage {
  INQUIRY
  APPLICATION
  ENTRANCE_TEST
  INTERVIEW
  OFFER
  FEE_PAID
  ENROLLED
}

enum CalendarEventType {
  EXAM
  HOLIDAY
  EVENT
  PTM
  SPORTS
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  PUBLISHED
}

enum HomeworkStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum FeeHeadCategory {
  TUITION
  ADMISSION
  EXAM
  TRANSPORT
  LIBRARY
  LAB
  SPORTS
  MEALS
  UNIFORM
  LATE_FINE
  OTHER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  UPI
  NET_BANKING
  CHALLAN
  CASH
}

enum ScholarshipType {
  MERIT
  NEED
  STAFF_WARD
  SPORTS
  OTHER
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum EmploymentType {
  TEACHING
  NON_TEACHING
  CONTRACT
}

enum LeaveType {
  CL
  SL
  EL
  ML
  PL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollRunStatus {
  DRAFT
  PROCESSED
  PAID
}

enum PayrollEntryStatus {
  DRAFT
  PROCESSED
  PAID
}

enum SubstitutionStatus {
  PENDING
  ASSIGNED
  COMPLETED
}

enum ClubMembershipStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum UniformOrderStatus {
  PENDING
  CONFIRMED
  FULFILLED
  CANCELLED
}

enum NoticeCategory {
  ACADEMIC
  SPORTS
  HOLIDAY
  EXAM
  GENERAL
}

enum AssetStatus {
  AVAILABLE
  CHECKED_OUT
  MAINTENANCE
  RETIRED
}

enum AlumniCampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum DeliveryChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum DeliveryStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

// ─── Tenant (School) ─────────────────────────────────────────────────────────

model School {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  plan         TenantPlan @default(CORE)
  logoUrl      String?
  primaryColor String?
  domain       String?
  isVerified   Boolean    @default(false)
  isActive     Boolean    @default(true)
  studentCount Int        @default(0)
  settings     Json       @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  students              Student[]
  classes               Class[]
  sections              Section[]
  subjects              Subject[]
  subscriptions         Subscription[]
  auditLogs             AuditLog[]
  admissionApplications AdmissionApplication[]
  classSeatCapacities   ClassSeatCapacity[]
  timetableSlots        TimetableSlot[]
  exams                 Exam[]
  calendarEvents        CalendarEvent[]
  homeworkAssignments   HomeworkAssignment[]
  feeHeads              FeeHead[]
  classFeeMatrices      ClassFeeMatrix[]
  scholarships          Scholarship[]
  feeConcessions        FeeConcession[]
  studentInvoices       StudentInvoice[]
  payments              Payment[]
  paymentGatewayConfigs PaymentGatewayConfig[]
  attendanceRecords     AttendanceRecord[]
  employeeProfiles      EmployeeProfile[]
  leaveRequests         LeaveRequest[]
  payrollRuns           PayrollRun[]
  substitutionAssignments SubstitutionAssignment[]
  libraryBooks            LibraryBook[]
  transportRoutes         TransportRoute[]
  clubs                   Club[]
  uniformItems            UniformItem[]
  bookstoreItems          BookstoreItem[]
  notices                 Notice[]
  circulars               Circular[]
  complaintThreads        ComplaintThread[]
  broadcastCampaigns      BroadcastCampaign[]
  notificationLogs        NotificationLog[]
  assets                  Asset[]
  alumniProfiles          AlumniProfile[]
  alumniCampaigns         AlumniCampaign[]
  hostelBlocks            HostelBlock[]
  inventoryItems          InventoryItem[]

  @@index([slug])
  @@index([plan])
  @@index([isActive])
  @@map("schools")
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  role         UserRole
  schoolId     String?
  isActive     Boolean   @default(true)
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?
  lastLoginAt  DateTime?
  deletionRequestedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school        School?        @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]
  sessions      Session[]
  devices       Device[]
  loginHistory  LoginHistory[]
  student              Student?
  timetableSlots       TimetableSlot[]      @relation("TimetableTeacher")
  homeworkAssignments  HomeworkAssignment[] @relation("HomeworkCreator")
  parentLinks          ParentStudent[]      @relation("ParentLinks")
  attendanceMarked     AttendanceRecord[]   @relation("AttendanceMarker")
  employeeProfile      EmployeeProfile?
  leaveRequests        LeaveRequest[]       @relation("LeaveEmployee")
  substituteLeaves     LeaveRequest[]       @relation("LeaveSubstitute")
  leaveBalances        LeaveBalance[]
  payrollEntries       PayrollEntry[]
  absentSubstitutions  SubstitutionAssignment[] @relation("AbsentTeacher")
  substituteAssignments SubstitutionAssignment[] @relation("SubstituteTeacher")
  advisedClubs          Club[]                   @relation("ClubAdvisor")
  noticesCreated        Notice[]                 @relation("NoticeCreator")
  circularsCreated      Circular[]               @relation("CircularCreator")
  complaintsSubmitted   ComplaintThread[]        @relation("ComplaintSubmitter")
  complaintsAssigned    ComplaintThread[]        @relation("ComplaintAssignee")
  complaintMessages     ComplaintMessage[]       @relation("ComplaintMessageSender")
  broadcastsCreated     BroadcastCampaign[]      @relation("BroadcastCreator")
  notificationLogs      NotificationLog[]        @relation("NotificationRecipient")
  inAppNotifications    InAppNotification[]
  assetCheckouts        AssetCheckout[]
  consent               UserConsent?

  @@index([schoolId, role])
  @@index([schoolId, isActive])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(cuid())
  token      String    @unique
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  deviceInfo String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model Device {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String
  name        String?
  lastUsedAt  DateTime @default(now())
  isTrusted   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
  @@map("devices")
}

model LoginHistory {
  id            String   @id @default(cuid())
  userId        String
  ipAddress     String?
  userAgent     String?
  success       Boolean
  failureReason String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("login_history")
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model Permission {
  id     String @id @default(cuid())
  code   String @unique
  name   String
  module String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  role         UserRole
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@index([role])
  @@index([permissionId])
  @@map("role_permissions")
}

// ─── Billing ─────────────────────────────────────────────────────────────────

model Plan {
  id           String  @id @default(cuid())
  name         String
  code         String  @unique
  priceMonthly Decimal @db.Decimal(10, 2)
  features     Json    @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id        String             @id @default(cuid())
  schoolId  String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime?
  mrr       Decimal            @db.Decimal(10, 2) @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([schoolId, status])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  ipAddress String?
  createdAt DateTime @default(now())

  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Academic ────────────────────────────────────────────────────────────────

model Class {
  id           String  @id @default(cuid())
  schoolId     String
  name         String
  grade        String
  academicYear String?
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school              School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sections            Section[]
  students            Student[]
  timetableSlots      TimetableSlot[]
  examScheduleEntries ExamScheduleEntry[]
  homeworkAssignments HomeworkAssignment[]
  substitutionAssignments SubstitutionAssignment[]

  @@unique([schoolId, name, academicYear])
  @@index([schoolId, isActive])
  @@index([schoolId, grade])
  @@map("classes")
}

model Section {
  id       String  @id @default(cuid())
  schoolId String
  classId  String
  name     String
  capacity Int?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class               Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  students            Student[]
  timetableSlots      TimetableSlot[]
  homeworkAssignments HomeworkAssignment[]
  substitutionAssignments SubstitutionAssignment[]

  @@unique([classId, name])
  @@index([schoolId, classId])
  @@index([schoolId, isActive])
  @@map("sections")
}

model Subject {
  id           String  @id @default(cuid())
  schoolId     String
  name         String
  code         String
  className    String?
  academicYear String?
  maxMarks     Int     @default(100)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school              School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  timetableSlots      TimetableSlot[]
  examScheduleEntries ExamScheduleEntry[]
  examResults         ExamResult[]
  homeworkAssignments HomeworkAssignment[]

  @@index([schoolId, isActive])
  @@index([schoolId, className, academicYear])
  @@map("subjects")
}

model Student {
  id          String        @id @default(cuid())
  schoolId    String
  userId      String?       @unique
  admissionNo String
  firstName   String
  lastName    String
  classId     String?
  sectionId   String?
  status      StudentStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  class       Class?       @relation(fields: [classId], references: [id], onDelete: SetNull)
  section       Section?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  examResults   ExamResult[]
  feeConcessions FeeConcession[]
  invoices          StudentInvoice[]
  payments          Payment[]
  parentLinks       ParentStudent[]
  attendanceRecords AttendanceRecord[]
  libraryIssues     LibraryIssue[]
  transportAlloc    StudentTransport?
  healthRecord      HealthRecord?
  infirmaryVisits   InfirmaryVisit[]
  clubMemberships   ClubMembership[]
  uniformOrders     UniformOrder[]
  bookstoreIssues   BookstoreIssue[]
  hostelResidents   HostelResident[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId, status])
  @@index([schoolId, classId])
  @@index([schoolId, sectionId])
  @@index([classId, sectionId])
  @@map("students")
}

// ─── Academic Operations ─────────────────────────────────────────────────────

model AdmissionApplication {
  id              String         @id @default(cuid())
  schoolId        String
  applicantName   String
  parentName      String
  parentEmail     String
  parentPhone     String
  targetClass     String
  previousSchool  String?
  gender          String?
  dateOfBirth     DateTime?
  address         String?
  parentWhatsapp  String?
  stage           AdmissionStage @default(INQUIRY)
  aiScore         Float?
  documents       Json           @default("[]")
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, stage])
  @@map("admission_applications")
}

model ClassSeatCapacity {
  id           String @id @default(cuid())
  schoolId     String
  grade        String
  totalSeats   Int
  filledSeats  Int    @default(0)
  academicYear String

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, grade, academicYear])
  @@index([schoolId, academicYear])
  @@map("class_seat_capacities")
}

model TimetableSlot {
  id        String  @id @default(cuid())
  schoolId  String
  classId   String?
  sectionId String?
  teacherId String?
  subjectId String?
  dayOfWeek Int
  period    Int
  startTime String
  endTime   String
  room      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class   Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  section Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  teacher User?    @relation("TimetableTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@unique([classId, sectionId, dayOfWeek, period])
  @@index([schoolId, classId])
  @@index([schoolId, teacherId])
  @@map("timetable_slots")
}

model Exam {
  id           String     @id @default(cuid())
  schoolId     String
  name         String
  term         String
  academicYear String
  status       ExamStatus @default(DRAFT)
  startDate    DateTime
  endDate      DateTime
  classes      Json       @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school          School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  scheduleEntries ExamScheduleEntry[]
  results         ExamResult[]

  @@index([schoolId, status])
  @@index([schoolId, academicYear])
  @@map("exams")
}

model ExamScheduleEntry {
  id        String   @id @default(cuid())
  examId    String
  subjectId String
  classId   String
  date      DateTime @db.Date
  startTime String
  endTime   String
  room      String?
  maxMarks  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([examId, classId])
  @@map("exam_schedule_entries")
}

model ExamResult {
  id            String  @id @default(cuid())
  examId        String
  studentId     String
  subjectId     String
  marksObtained Float
  maxMarks      Int
  grade         String?
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId, subjectId])
  @@index([examId, studentId])
  @@map("exam_results")
}

model CalendarEvent {
  id          String            @id @default(cuid())
  schoolId    String
  title       String
  type        CalendarEventType
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean           @default(false)
  description String?
  classIds    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, startDate])
  @@index([schoolId, type])
  @@map("calendar_events")
}

model HomeworkAssignment {
  id          String         @id @default(cuid())
  schoolId    String
  title       String
  subjectId   String
  classId     String
  sectionId   String?
  dueDate     DateTime
  status      HomeworkStatus @default(DRAFT)
  description String?
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  createdBy User     @relation("HomeworkCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([schoolId, classId])
  @@index([schoolId, status])
  @@map("homework_assignments")
}

// ─── Finance ─────────────────────────────────────────────────────────────────

model FeeHead {
  id          String          @id @default(cuid())
  schoolId    String
  name        String
  code        String
  category    FeeHeadCategory
  amount      Decimal         @default(0) @db.Decimal(10, 2)
  isActive    Boolean         @default(true)
  isMandatory Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school           School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classFeeMatrices ClassFeeMatrix[]
  invoiceLineItems InvoiceLineItem[]

  @@unique([schoolId, code])
  @@index([schoolId, isActive])
  @@index([schoolId, category])
  @@map("fee_heads")
}

model ClassFeeMatrix {
  id           String  @id @default(cuid())
  schoolId     String
  grade        String
  feeHeadId    String
  amount       Decimal @db.Decimal(10, 2)
  academicYear String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeHead FeeHead @relation(fields: [feeHeadId], references: [id], onDelete: Cascade)

  @@unique([schoolId, grade, feeHeadId, academicYear])
  @@index([schoolId, academicYear])
  @@index([schoolId, grade])
  @@map("class_fee_matrices")
}

model Scholarship {
  id              String           @id @default(cuid())
  schoolId        String
  name            String
  type            ScholarshipType
  discountPercent Decimal          @db.Decimal(5, 2)
  description     String?
  isActive        Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school      School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  concessions FeeConcession[]

  @@index([schoolId, isActive])
  @@map("scholarships")
}

model FeeConcession {
  id              String    @id @default(cuid())
  schoolId        String
  studentId       String
  scholarshipId   String?
  discountPercent Decimal   @db.Decimal(5, 2)
  reason          String?
  validUntil      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scholarship Scholarship? @relation(fields: [scholarshipId], references: [id], onDelete: SetNull)

  @@index([schoolId, studentId])
  @@map("fee_concessions")
}

model StudentInvoice {
  id           String        @id @default(cuid())
  schoolId     String
  studentId    String
  invoiceNo    String
  academicYear String
  term         String
  totalAmount  Decimal       @db.Decimal(10, 2)
  paidAmount   Decimal       @default(0) @db.Decimal(10, 2)
  dueDate      DateTime
  status       InvoiceStatus @default(ISSUED)
  lateFine     Decimal       @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@unique([schoolId, invoiceNo])
  @@index([schoolId, studentId])
  @@index([schoolId, status])
  @@index([schoolId, dueDate])
  @@map("student_invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  feeHeadId   String
  description String
  amount      Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice StudentInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  feeHead FeeHead        @relation(fields: [feeHeadId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id            String        @id @default(cuid())
  schoolId      String
  studentId     String
  invoiceId     String?
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  gatewayRef    String?
  receiptNo     String?
  paidAt        DateTime?
  metadata      Json          @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  invoice StudentInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([schoolId, studentId])
  @@index([schoolId, status])
  @@index([invoiceId])
  @@map("payments")
}

model PaymentGatewayConfig {
  id              String  @id @default(cuid())
  schoolId        String
  provider        String
  isEnabled       Boolean @default(false)
  encryptedConfig Json    @default("{}")
  isTestMode      Boolean @default(true)

